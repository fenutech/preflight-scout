{
  "name": "preflight-scout",
  "version": "0.1.2",
  "private": true,
  "description": "Release QA for pull requests: focused checks, browser evidence, and explicit readiness.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.12.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:ci": "node scripts/run-test-suite.mjs unit",
    "test:browser": "node scripts/run-test-suite.mjs browser",
    "playwright:install": "pnpm --filter @preflight-scout/browser-runner exec playwright install chromium",
    "playwright:install:ci": "pnpm --filter @preflight-scout/browser-runner exec playwright install --with-deps chromium",
    "install:source-cli": "node scripts/install-source-cli.mjs",
    "prepare:packages": "node scripts/sync-package-assets.mjs",
    "check:package-assets": "node scripts/sync-package-assets.mjs --check",
    "test:package-guard": "node scripts/test-package-build-integrity.mjs",
    "test:source-cli-wrapper": "node scripts/test-source-cli-wrapper.mjs",
    "test:repo-boundary": "node scripts/test-repository-boundary.mjs",
    "test:publication": "node scripts/test-publication-gates.mjs && node scripts/test-publication-artifact.mjs",
    "test:external-tools": "node scripts/test-external-tool-resolution.mjs",
    "pack:check": "pnpm test:package-guard && pnpm test:source-cli-wrapper && pnpm test:external-tools && pnpm check:package-assets && node scripts/verify-packed-packages.mjs --prepare && pnpm -r --filter \"./packages/*\" pack --pack-destination .preflight-scout/package-check && node scripts/verify-packed-packages.mjs",
    "smoke:install": "node scripts/clean-install-smoke.mjs",
    "smoke:npm-global": "node scripts/npm-global-install-smoke.mjs",
    "test:npm-global-smoke": "node scripts/test-npm-global-install-smoke.mjs",
    "check:repo": "node scripts/verify-repository-boundary.mjs && node scripts/verify-repository.mjs",
    "check:site": "pnpm --filter @preflight-scout/site check && node scripts/verify-cloudflare-pages.mjs",
    "check:release-version": "node scripts/verify-release-version.mjs",
    "test:release-version": "node scripts/test-release-version.mjs",
    "check:release-order": "node scripts/verify-release-order.mjs",
    "test:release-order": "node scripts/test-release-order.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "test:prepare-release": "node scripts/test-prepare-release.mjs",
    "test:skill": "python3 skills/scripts/test-skill-tooling.py",
    "package:skill": "skills/scripts/package-skill.sh",
    "typecheck": "tsc -b packages/*",
    "dev": "tsx packages/cli/src/index.ts",
    "preflight-scout": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
