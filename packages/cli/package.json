{
  "name": "@preflight-scout/cli",
  "version": "0.1.3",
  "description": "CLI for pull-request impact reports and browser QA missions.",
  "keywords": ["preflight-scout", "release-qa", "pull-request", "playwright", "agent-skill"],
  "author": "Andrea Fenu",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/fenutech/preflight-scout#readme",
  "bugs": { "url": "https://github.com/fenutech/preflight-scout/issues" },
  "type": "module",
  "engines": { "node": ">=22.13.0" },
  "bin": {
    "preflight-scout": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "OUTPUT-LICENSE.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": { "access": "public", "provenance": true },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fenutech/preflight-scout.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "node ../../scripts/package-build-integrity.mjs clean && tsc -p tsconfig.json && node ../../scripts/package-build-integrity.mjs write",
    "prepack": "node ../../scripts/package-build-integrity.mjs verify",
    "prepublishOnly": "node ../../scripts/package-build-integrity.mjs verify"
  },
  "dependencies": {
    "@preflight-scout/agent-exec": "workspace:*",
    "@preflight-scout/browser-runner": "workspace:*",
    "@preflight-scout/core": "workspace:*",
    "@preflight-scout/mcp": "workspace:*",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1"
  }
}
